{
  "name": "yt-jam-desktop-pet",
  "version": "1.0.0",
  "private": true,
  "description": "Transparent always-on-top vibe companion that floats over your screen and reacts to the genre of music playing in your YT Jam room.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --win portable"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ytjam.companion",
    "productName": "YT Jam Companion",
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "files": [
      "main.js",
      "pet.html",
      "pet.js",
      "node_modules/**/*"
    ]
  }
}
